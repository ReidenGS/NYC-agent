# =====================================================================
# NYC Agent shared environment template
# Copy this file to `.env` and fill real values. Do NOT commit `.env`.
# =====================================================================

# ---------- PostgreSQL + PostGIS ----------
POSTGRES_USER=nyc_agent
POSTGRES_PASSWORD=nyc_agent_password
POSTGRES_DB=nyc_agent
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Canonical DSNs. Two driver flavours coexist:
#   *_SYNC*  -> psycopg (used by data-sync-service and any sync FastAPI code)
#   *_ASYNC* -> asyncpg (used by api-gateway / agents that go async)
# Pick the variant that matches your service. `_DOCKER` versions point at
# `postgres` host inside the compose network; the others use localhost.
DATABASE_URL_SYNC=postgresql+psycopg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_SYNC_DOCKER=postgresql+psycopg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent
DATABASE_URL_ASYNC=postgresql+asyncpg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_ASYNC_DOCKER=postgresql+asyncpg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent

# Legacy alias kept for backward compat — services should prefer the
# explicit *_SYNC / *_ASYNC variants above.
DATABASE_URL=postgresql+psycopg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_DOCKER=postgresql+psycopg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# ---------- Data Sync Service ----------
DATA_SYNC_PORT=8030
SYNC_ENABLE_SCHEDULED_JOBS=false
SYNC_BOOTSTRAP_AREAS=Astoria,Long Island City,Williamsburg,Greenpoint,Midtown,East Village,Upper West Side,Sunnyside,Bushwick,Downtown Brooklyn

RENTCAST_SYNC_ENABLED=false
RENTCAST_MAX_CALLS_PER_RUN=5
RENTCAST_MAX_CALLS_PER_MONTH=50

OVERPASS_MAX_REQUESTS_PER_RUN=10
OVERPASS_SLEEP_SECONDS=3

SOCRATA_PAGE_SIZE=1000
SOCRATA_MAX_ROWS_PER_JOB=50000

MAP_LAYER_PREGENERATE_FOR_SEED=true

# ---------- External API keys (fill in real values; placeholders only) ----------
# NYC Open Data (Socrata) app token — optional but recommended
SOCRATA_APP_TOKEN=
# RentCast — required for housing sync (manual trigger only)
RENTCAST_API_KEY=
# HUD USER Fair Market Rent API — JWT bearer token from huduser.gov
HUD_USER_API_TOKEN=
