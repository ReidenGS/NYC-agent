# =====================================================================
# NYC Agent shared environment template
# Copy this file to `.env` and fill real values. Do NOT commit `.env`.
# =====================================================================

# ---------- PostgreSQL + PostGIS ----------
POSTGRES_USER=nyc_agent
POSTGRES_PASSWORD=nyc_agent_password
POSTGRES_DB=nyc_agent
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Canonical DSNs. Two driver flavours coexist:
#   *_SYNC*  -> psycopg (used by data-sync-service and any sync FastAPI code)
#   *_ASYNC* -> asyncpg (used by api-gateway / agents that go async)
# Pick the variant that matches your service. `_DOCKER` versions point at
# `postgres` host inside the compose network; the others use localhost.
DATABASE_URL_SYNC=postgresql+psycopg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_SYNC_DOCKER=postgresql+psycopg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent
DATABASE_URL_ASYNC=postgresql+asyncpg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_ASYNC_DOCKER=postgresql+asyncpg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent
DATABASE_URL_SQL=postgresql+psycopg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_SQL_DOCKER=postgresql+psycopg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent

# Legacy alias kept for backward compat — services should prefer the
# explicit *_SYNC / *_ASYNC variants above.
DATABASE_URL=postgresql+psycopg://nyc_agent:nyc_agent_password@localhost:5432/nyc_agent
DATABASE_URL_DOCKER=postgresql+psycopg://nyc_agent:nyc_agent_password@postgres:5432/nyc_agent

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# ---------- API Gateway ----------
API_GATEWAY_PORT=8000
API_GATEWAY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
USE_REMOTE_ORCHESTRATOR=true
ORCHESTRATOR_AGENT_URL=http://localhost:8010
ORCHESTRATOR_AGENT_URL_DOCKER=http://orchestrator-agent:8010
HOUSING_AGENT_URL=http://localhost:8011
HOUSING_AGENT_URL_DOCKER=http://housing-agent:8011
NEIGHBORHOOD_AGENT_URL=http://localhost:8012
NEIGHBORHOOD_AGENT_URL_DOCKER=http://neighborhood-agent:8012
TRANSIT_AGENT_URL=http://localhost:8013
TRANSIT_AGENT_URL_DOCKER=http://transit-agent:8013
WEATHER_AGENT_URL=http://localhost:8015
WEATHER_AGENT_URL_DOCKER=http://weather-agent:8015
DATA_SYNC_BASE_URL=http://localhost:8030
DATA_SYNC_BASE_URL_DOCKER=http://data-sync-service:8030

# ---------- Agent Services ----------
ORCHESTRATOR_AGENT_PORT=8010
HOUSING_AGENT_PORT=8011
NEIGHBORHOOD_AGENT_PORT=8012
TRANSIT_AGENT_PORT=8013
PROFILE_AGENT_PORT=8014
WEATHER_AGENT_PORT=8015
MCP_SQL_PORT=8020
MCP_SAFETY_PORT=8022
MCP_AMENITY_PORT=8023
MCP_ENTERTAINMENT_PORT=8024
MCP_TRANSIT_PORT=8025
MCP_PROFILE_PORT=8026
MCP_WEATHER_PORT=8027
PROFILE_AGENT_URL=http://localhost:8014
PROFILE_AGENT_URL_DOCKER=http://profile-agent:8014
MCP_SQL_URL=http://localhost:8020
MCP_SQL_URL_DOCKER=http://mcp-sql:8020
MCP_SAFETY_URL=http://localhost:8022
MCP_SAFETY_URL_DOCKER=http://mcp-safety:8022
MCP_AMENITY_URL=http://localhost:8023
MCP_AMENITY_URL_DOCKER=http://mcp-amenity:8022
MCP_ENTERTAINMENT_URL=http://localhost:8024
MCP_ENTERTAINMENT_URL_DOCKER=http://mcp-entertainment:8022
MCP_TRANSIT_URL=http://localhost:8025
MCP_TRANSIT_URL_DOCKER=http://mcp-transit:8025
MCP_PROFILE_URL=http://localhost:8026
MCP_PROFILE_URL_DOCKER=http://mcp-profile:8026
MCP_WEATHER_URL=http://localhost:8027
MCP_WEATHER_URL_DOCKER=http://mcp-weather:8027
SQL_STATEMENT_TIMEOUT_MS=3000
PROFILE_STORE_BACKEND=postgres
PROFILE_STATEMENT_TIMEOUT_MS=3000
TRANSIT_STATEMENT_TIMEOUT_MS=3000
TRANSIT_REALTIME_ENABLED=true
TRANSIT_REALTIME_TTL_SECONDS=60
TRANSIT_REALTIME_REQUEST_TIMEOUT_SECONDS=5
MTA_SUBWAY_FEED_BASE_URL=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds/nyct%2F
MTA_BUS_GTFS_RT_TRIP_UPDATES_URL=https://gtfsrt.prod.obanyc.com/tripUpdates

# ---------- LLM Providers ----------
# Domain SQL planners use GPT-4o when OPENAI_API_KEY is set.
# If the key is empty or a planner call fails, services fall back to deterministic SQL plans.
USE_LLM_SQL_PLANNER=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
HOUSING_AGENT_SQL_MODEL=gpt-4o
NEIGHBORHOOD_AGENT_SQL_MODEL=gpt-4o
LLM_REQUEST_TIMEOUT_SECONDS=20

# ---------- Data Sync Service ----------
DATA_SYNC_PORT=8030
SYNC_ENABLE_SCHEDULED_JOBS=false
SYNC_BOOTSTRAP_AREAS=Astoria,Long Island City,Williamsburg,Greenpoint,Midtown,East Village,Upper West Side,Sunnyside,Bushwick,Downtown Brooklyn

RENTCAST_SYNC_ENABLED=false
RENTCAST_MAX_CALLS_PER_RUN=5
RENTCAST_MAX_CALLS_PER_MONTH=50

OVERPASS_MAX_REQUESTS_PER_RUN=10
OVERPASS_SLEEP_SECONDS=3

SOCRATA_PAGE_SIZE=1000
SOCRATA_MAX_ROWS_PER_JOB=50000

MAP_LAYER_PREGENERATE_FOR_SEED=true

# Optional override for MTA bus static GTFS zip feeds. Leave empty to use
# built-in official MTA feed URLs.
MTA_BUS_STATIC_FEED_URLS=

# ---------- External API keys (fill in real values; placeholders only) ----------
# NYC Open Data (Socrata) app token — optional but recommended
SOCRATA_APP_TOKEN=
# RentCast — required for housing sync (manual trigger only)
RENTCAST_API_KEY=
# HUD USER Fair Market Rent API — JWT bearer token from huduser.gov
HUD_USER_API_TOKEN=
# MTA subway GTFS-RT — optional API key from api.mta.info
MTA_API_KEY=
# MTA Bus Time GTFS-RT — required for bus realtime predictions
MTA_BUS_TIME_API_KEY=

# National Weather Service requires a descriptive User-Agent, no API key required.
NWS_USER_AGENT=NYC-agent-demo/0.1-your-email@example.com
